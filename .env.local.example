# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_PRICE_ID=price_...

# Stripe Payment Links — one-time credit packs (no API integration needed)
# Create these in the Stripe dashboard as Payment Links and paste the resulting URLs here.
# The webhook adds 10 credits for $9 ($amount_total === 900) or 25 credits for $19 ($amount_total === 1900).
NEXT_PUBLIC_STRIPE_STARTER_URL=https://buy.stripe.com/eVqdR95gFdLV4M3cF8gjC0l
NEXT_PUBLIC_STRIPE_PRO_URL=https://buy.stripe.com/28E6oH7oNePZ92j20ugjC0m

# OpenAI
OPENAI_API_KEY=sk-...

# Pexels (stock footage — falls back to mock if missing)
PEXELS_API_KEY=your_key_here

# Creatomate (final MP4 rendering — returns mock render if missing)
CREATOMATE_API_KEY=your_key_here

# Pixabay (background music — optional, defaults to curated CDN list if missing)
PIXABAY_API_KEY=your_key_here

# App
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
